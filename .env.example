# ============================================================
# AutoClipper — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (Prisma format)
DATABASE_URL="postgresql://autoclipper:changeme@localhost:5432/autoclipper_db?schema=public"

# ── Redis ────────────────────────────────────────────────────
# Used by BullMQ for job queuing
REDIS_URL=redis://localhost:6379

# ── Google AI Studio (Gemini) ────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Model to use for video analysis (gemini-1.5-pro supports video)
GEMINI_MODEL=gemini-1.5-pro

# ── TikTok ───────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
# Must match the redirect URI registered in TikTok developer console
TIKTOK_REDIRECT_URI=http://localhost:3000/auth/tiktok/callback

# ── AWS S3 / MinIO ───────────────────────────────────────────
# For AWS S3: set STORAGE_ENDPOINT to empty string
# For MinIO (local dev): set STORAGE_ENDPOINT to your MinIO URL
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_FORCE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET_NAME=autoclipper

# ── FFmpeg ───────────────────────────────────────────────────
# Absolute path to the ffmpeg binary (leave empty to use PATH)
FFMPEG_PATH=
# Temporary directory for worker scratch space
WORKER_TMP_DIR=/tmp/autoclipper

# ── Session / Security ───────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string_in_production
JWT_SECRET=another_long_random_string_for_jwt_tokens
JWT_EXPIRES_IN=7d

# ── BullMQ Worker Concurrency ────────────────────────────────
# Number of parallel video-processing jobs per worker process
VIDEO_WORKER_CONCURRENCY=2
CAPTION_WORKER_CONCURRENCY=4
